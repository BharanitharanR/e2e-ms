# e2e-marqeta-simulator/docker-compose.yml
services:

  # ── Existing services ────────────────────────────────────────────────────────

  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    ports:
      - "8000:8000"
    environment:
      - ACQUIRER_URL=http://acquirer:8101/authorize
      - CUSTOMER_JIT_RESET_URL=http://customer_jit:8001/reset
      - DB_PATH=/data/simulator.db
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - CUSTOMER_JIT_URL=http://customer_jit:8001
      - ACQUIRER_SVC_URL=http://acquirer:8101
      - VISA_SVC_URL=http://visa:8102
      - MARQETA_SIM_URL=http://marqeta_simulator:8103
      # ── OTel additions ──────────────────────────────────────────────────────
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
      - OTEL_SERVICE_NAME=marqeta-e2e-backend
    volumes:
      - simulator_data:/data
    depends_on:
      - acquirer
      - customer_jit
      - otel-collector      # wait for collector before emitting spans

  acquirer:
    build:
      context: .
      dockerfile: Dockerfile.acquirer
    ports:
      - "8101:8101"
    environment:
      - VISA_URL=http://visa:8102/network/authorize
    depends_on:
      - visa

  visa:
    build:
      context: .
      dockerfile: Dockerfile.visa
    ports:
      - "8102:8102"
    environment:
      - MARQETA_URL=http://marqeta_simulator:8103/issuer/authorize
    depends_on:
      - marqeta_simulator

  marqeta_simulator:
    build:
      context: .
      dockerfile: Dockerfile.marqeta_simulator
    ports:
      - "8103:8103"
    environment:
      - CUSTOMER_JIT_URL=http://customer_jit:8001/jit/authorize
    depends_on:
      - customer_jit

  customer_jit:
    build:
      context: .
      dockerfile: Dockerfile.customer_jit
    ports:
      - "8001:8001"
    environment:
      - BLOCKED_MCCS=${BLOCKED_MCCS:-6011,4829}
      - DAILY_LIMIT_CENTS=${DAILY_LIMIT_CENTS:-0}
      - VELOCITY_MAX_TXN=${VELOCITY_MAX_TXN:-0}

  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
    ports:
      - "8501:8501"
    environment:
      - API_URL=http://backend:8000
    depends_on:
      - backend

  ollama:
    build:
      context: .
      dockerfile: Dockerfile.ollama
    container_name: ollama
    ports:
      - "11434:11434"
    environment:
      OLLAMA_MODEL: qwen3:8b
    volumes:
      - ollama_data:/root/.ollama

  mongodb:
    image: mongo:7
    container_name: mongodb
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db

  # ── OTel observability stack ─────────────────────────────────────────────────

  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.100.0
    container_name: otel-collector
    command: ["--config=/etc/otel-collector-config.yaml"]
    volumes:
      - ./otel/collector-config.yaml:/etc/otel-collector-config.yaml:ro
    ports:
      - "4317:4317"    # OTLP gRPC  — backend → collector
      - "4318:4318"    # OTLP HTTP
      - "8889:8889"    # Prometheus scrape endpoint
    depends_on:
      - jaeger
    restart: unless-stopped

  prometheus:
    image: prom/prometheus:v2.51.0
    container_name: prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time=7d"
      - "--web.enable-lifecycle"
    volumes:
      - ./otel/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    ports:
      - "9090:9090"
    depends_on:
      - otel-collector
    restart: unless-stopped

  grafana:
    image: grafana/grafana:10.4.2
    container_name: grafana
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=admin
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/ollama-analytics.json
    volumes:
      - ./otel/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./otel/grafana/dashboards:/var/lib/grafana/dashboards:ro
      - grafana_data:/var/lib/grafana
    ports:
      - "3000:3000"
    depends_on:
      - prometheus
    restart: unless-stopped

  jaeger:
    image: jaegertracing/all-in-one:1.57
    container_name: jaeger
    environment:
      - COLLECTOR_OTLP_ENABLED=true
    ports:
      - "16686:16686"    # Jaeger UI
      - "14250:14250"    # gRPC ingest from otel-collector
    restart: unless-stopped

volumes:
  simulator_data:
  mongo_data:
  ollama_data:
  prometheus_data:
  grafana_data:
